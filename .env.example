# Copia este archivo como .env y completa los valores reales localmente.

# App
PORT=8000
DEBUG=false
VERCEL=0

# Firebase
FIREBASE_DATABASE_URL=
FIREBASE_PRIVATE_KEY_JSON_BASE64=
# FIREBASE_PRIVATE_KEY_JSON=
# FIREBASE_CREDENTIALS_PATH=

# Seguridad JWT
# AUTH_PROVIDER=firebase usa Firebase Auth para usuarios humanos.
# ALLOW_LEGACY_PASSWORD_LOGIN solo debe quedar true en pruebas o migracion temporal.
AUTH_PROVIDER=firebase
ALLOW_LEGACY_PASSWORD_LOGIN=false
CHECK_FIREBASE_TOKEN_REVOKED=true
DISABLE_FIREBASE_AUTH_USER_MANAGEMENT=false
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Firebase Auth Web SDK (config publica, no credencial secreta)
FIREBASE_WEB_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=

# Usuario administrador inicial
ADMIN_USERNAME=
ADMIN_ROLE=admin
ADMIN_STATUS=activo
ADMIN_FIREBASE_UID=
ADMIN_PASSWORD_HASH=
ADMIN_EMAIL=
ADMIN_FULL_NAME=
ADMIN_DISABLED=false

# Almacenamiento de usuarios
USER_STORE_PATH=/app_users
DISABLE_FIREBASE_USER_STORE=false

# Consentimiento TyC
TERMS_VERSION=2026-05-31
TERMS_REQUIRED_ROLES=admin,auditor
TERMS_CONSENT_STORE_PATH=/app_consents

# Laboratorio monitoreado
LAB_ROOM_ID=LAB-PC-01
LAB_ROOM_NAME=Laboratorio de Computo
MONITORED_SENSOR_IDS=C-01,C-02,C-03,C-04,C-05,C-06,C-07,C-08,C-09,C-10
SIMULATED_BRANCH_IDS=C-01,C-02,C-03,C-04,C-05,C-06,C-07,C-08,C-09,C-10
PHYSICAL_BRANCH_ID=C-01
APP_LOCAL_UTC_OFFSET_HOURS=-5
BRANCH_RESIDUAL_MAX_CURRENT_A=0.16
BRANCH_ONE_PC_MAX_CURRENT_A=0.20
BRANCH_ONE_PC_WORKLOAD_MAX_CURRENT_A=0.23
BRANCH_TWO_PC_MAX_CURRENT_A=0.30
OUT_OF_SCHEDULE_MIN_CURRENT_A=0.16
SCHEDULE_STORE_PATH=/config/schedules
SAFYRA_IOT_TOKEN=
SAFYRA_BACKEND_URL=http://127.0.0.1:8000
IOT_SIMULATOR_TIMEOUT_SECONDS=30

# Integracion n8n para alertas externas
ALERT_NOTIFICATION_ENABLED=false
N8N_ALERT_WEBHOOK_URL=
N8N_ALERT_WEBHOOK_TOKEN=
N8N_ALERT_TIMEOUT_SECONDS=60
ALERT_NOTIFICATION_COOLDOWN_SECONDS=300
ALERT_RECIPIENT_ROLES=admin,auditor

# Tests
SKIP_FIREBASE_INIT=false
TEST_ADMIN_PASSWORD=
